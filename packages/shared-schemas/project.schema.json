{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video-creator.local/schemas/project.json",
  "title": "Project",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "name", "audio", "transcript", "output", "layers"],
  "properties": {
    "version": { "const": 1 },
    "name": { "type": "string", "minLength": 1, "maxLength": 200 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "project_id": { "type": "string", "minLength": 1 },
    "config_hash": { "type": "string", "minLength": 1 },
    "last_rendered_config_hash": { "type": "string", "minLength": 1 },
    "audio": { "type": "string" },
    "transcript": { "$ref": "#/$defs/Transcript" },
    "output": { "$ref": "#/$defs/Output" },
    "media": {
      "type": "array",
      "items": { "$ref": "#/$defs/MediaAsset" }
    },
    "layers": {
      "type": "array",
      "description": "Ordered top-to-bottom in render stack: subtitles first, background last.",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/SubtitlesLayer" },
          { "$ref": "#/$defs/ForegroundLayer" },
          { "$ref": "#/$defs/PipLayer" },
          { "$ref": "#/$defs/BackgroundLayer" }
        ],
        "discriminator": { "propertyName": "kind" }
      }
    },
    "subtitles": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/SubtitlesSettings" }]
    },
    "watermark": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/Watermark" }]
    }
  },
  "$defs": {
    "RuntimeState": {
      "title": "RuntimeState",
      "enum": ["ready", "unavailable", "unknown"]
    },
    "AlignmentState": {
      "title": "AlignmentState",
      "enum": ["aligned", "pending", "missing"]
    },
    "SetupAlignmentState": {
      "title": "SetupAlignmentState",
      "enum": ["pending", "running", "aligned", "failed"]
    },
    "DetectedVoiceState": {
      "title": "DetectedVoiceState",
      "enum": ["copied", "copying", "invalid"]
    },
    "DetectedTranscriptState": {
      "title": "DetectedTranscriptState",
      "enum": ["parsed", "empty", "invalid"]
    },
    "ProjectStatus": {
      "title": "ProjectStatus",
      "enum": ["ready", "missing", "corrupt", "alignment_pending", "alignment_failed", "rendering"]
    },
    "RenderStatus": {
      "title": "RenderStatus",
      "enum": [
        "idle",
        "queued",
        "verifying",
        "prerender",
        "subtitles",
        "composing",
        "muxing",
        "logging_history",
        "done",
        "cancelling",
        "cancelled",
        "failed",
        "output_missing",
        "partial_excluded",
        "ffmpeg_warning",
        "ffmpeg_fatal_error",
        "history_empty"
      ]
    },
    "LauncherRenderStatusTag": {
      "title": "LauncherRenderStatusTag",
      "enum": ["unrendered", "queued", "rendering", "rendered", "failed", "cancelled"]
    },
    "RenderPreset": {
      "title": "RenderPreset",
      "enum": ["draft", "final"]
    },
    "RenderResolution": {
      "title": "RenderResolution",
      "enum": ["1920x1080", "1280x720", "1080x1920"]
    },
    "RenderStage": {
      "title": "RenderStage",
      "enum": [
        "queued",
        "verify_alignment_cache",
        "pre_render_cached_clips",
        "build_subtitles_srt",
        "compose_filtergraph",
        "mux_mp4_faststart",
        "append_render_history_to_app_db"
      ]
    },
    "RenderPageState": {
      "title": "RenderPageState",
      "enum": [
        "idle",
        "queued",
        "verifying",
        "prerender",
        "subtitles",
        "composing",
        "muxing",
        "logging_history",
        "done",
        "cancelling",
        "cancelled",
        "failed",
        "output_missing",
        "partial_excluded",
        "ffmpeg_warning",
        "ffmpeg_fatal_error",
        "history_empty"
      ]
    },
    "SetupOutputPreset": {
      "title": "SetupOutputPreset",
      "enum": ["draft", "final", "vertical"]
    },
    "RenderArtifactKind": {
      "title": "RenderArtifactKind",
      "enum": [
        "output",
        "final_mp4",
        "draft_mp4",
        "partial",
        "log",
        "graph",
        "filtergraph",
        "subtitles",
        "thumbnail",
        "companion"
      ]
    },
    "MediaKind": {
      "title": "MediaKind",
      "enum": ["image", "video", "audio", "watermark_image", "watermark_video"]
    },
    "MediaRole": {
      "title": "MediaRole",
      "enum": ["background", "foreground", "pip", "watermark"]
    },
    "MediaImportMode": {
      "title": "MediaImportMode",
      "enum": ["copy", "link", "generated"]
    },
    "VisualCacheStatus": {
      "title": "VisualCacheStatus",
      "enum": ["warm", "partial", "cold", "invalid", "orphaned"]
    },
    "Dimensions": {
      "title": "Dimensions",
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      }
    },
    "MediaAsset": {
      "title": "MediaAsset",
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "kind", "path", "import_mode", "imported_at"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "kind": { "$ref": "#/$defs/MediaKind" },
        "role": { "$ref": "#/$defs/MediaRole" },
        "path": { "type": "string", "minLength": 1 },
        "thumb_path": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "dimensions": { "oneOf": [{ "$ref": "#/$defs/Dimensions" }, { "type": "null" }] },
        "duration": { "oneOf": [{ "type": "number", "minimum": 0 }, { "type": "null" }] },
        "size": { "oneOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] },
        "hash": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "import_mode": { "$ref": "#/$defs/MediaImportMode" },
        "created_at": { "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] },
        "imported_at": { "type": "string", "format": "date-time" }
      }
    },
    "SidecarStatus": {
      "title": "SidecarStatus",
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "address", "version"],
      "properties": {
        "status": { "$ref": "#/$defs/RuntimeState" },
        "address": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "VersionedRuntimeStatus": {
      "title": "VersionedRuntimeStatus",
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "version"],
      "properties": {
        "status": { "$ref": "#/$defs/RuntimeState" },
        "version": { "type": "string" }
      }
    },
    "CudaStatus": {
      "title": "CudaStatus",
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "available", "version", "gpu_label"],
      "properties": {
        "status": { "$ref": "#/$defs/RuntimeState" },
        "available": { "oneOf": [{ "type": "boolean" }, { "type": "null" }] },
        "version": { "type": "string" },
        "gpu_label": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
      }
    },
    "WhisperXStatus": {
      "title": "WhisperXStatus",
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "model"],
      "properties": {
        "status": { "$ref": "#/$defs/RuntimeState" },
        "model": { "type": "string" }
      }
    },
    "RuntimeHealthResponse": {
      "title": "RuntimeHealthResponse",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "version",
        "active_renders",
        "cached_projects",
        "sidecar",
        "node",
        "python",
        "ffmpeg",
        "cuda",
        "whisperx"
      ],
      "properties": {
        "status": { "const": "ok" },
        "version": { "type": "string" },
        "active_renders": { "type": "integer", "minimum": 0 },
        "cached_projects": { "type": "integer", "minimum": 0 },
        "sidecar": { "$ref": "#/$defs/SidecarStatus" },
        "node": { "$ref": "#/$defs/VersionedRuntimeStatus" },
        "python": { "$ref": "#/$defs/VersionedRuntimeStatus" },
        "ffmpeg": { "$ref": "#/$defs/VersionedRuntimeStatus" },
        "cuda": { "$ref": "#/$defs/CudaStatus" },
        "whisperx": { "$ref": "#/$defs/WhisperXStatus" }
      }
    },
    "RecentProject": {
      "title": "RecentProject",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "name",
        "last_render_at",
        "voice_duration",
        "sentence_count",
        "media_count",
        "alignment_state",
        "palette_seed"
      ],
      "properties": {
        "path": { "type": "string" },
        "name": { "type": "string" },
        "last_render_at": { "type": "string" },
        "voice_duration": { "type": "string" },
        "sentence_count": { "type": "integer", "minimum": 0 },
        "media_count": { "type": "integer", "minimum": 0 },
        "alignment_state": { "$ref": "#/$defs/AlignmentState" },
        "palette_seed": { "type": "string" }
      }
    },
    "RecentProjectCard": {
      "title": "RecentProjectCard",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id",
        "name",
        "voice_duration",
        "sentence_count",
        "media_count",
        "alignment_state",
        "status",
        "has_unrendered_changes"
      ],
      "properties": {
        "project_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "last_render_at": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "voice_duration": { "type": "string" },
        "sentence_count": { "type": "integer", "minimum": 0 },
        "media_count": { "type": "integer", "minimum": 0 },
        "alignment_state": { "$ref": "#/$defs/AlignmentState" },
        "status": { "$ref": "#/$defs/ProjectStatus" },
        "thumbnail_path": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "current_config_hash": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "last_rendered_config_hash": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "has_unrendered_changes": { "type": "boolean" },
        "latest_render_id": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "latest_render_status": { "oneOf": [{ "$ref": "#/$defs/RenderStatus" }, { "type": "null" }] },
        "render_status_tag": { "oneOf": [{ "$ref": "#/$defs/LauncherRenderStatusTag" }, { "type": "null" }] }
      }
    },
    "PaginationMeta": {
      "title": "PaginationMeta",
      "type": "object",
      "additionalProperties": false,
      "required": ["page_size", "page_index", "total_count", "total_pages"],
      "properties": {
        "page_size": { "type": "integer", "minimum": 1 },
        "page_index": { "type": "integer", "minimum": 0 },
        "total_count": { "type": "integer", "minimum": 0 },
        "total_pages": { "type": "integer", "minimum": 0 }
      }
    },
    "RecentProjectsPage": {
      "title": "RecentProjectsPage",
      "type": "object",
      "additionalProperties": false,
      "required": ["items", "pagination"],
      "properties": {
        "items": { "type": "array", "items": { "$ref": "#/$defs/RecentProjectCard" } },
        "pagination": { "$ref": "#/$defs/PaginationMeta" }
      }
    },
    "DetectedVoice": {
      "title": "DetectedVoice",
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "duration", "sample_rate", "channels", "codec", "state"],
      "properties": {
        "path": { "type": "string" },
        "duration": { "type": "number", "minimum": 0 },
        "sample_rate": { "type": "integer", "minimum": 0 },
        "channels": { "type": "integer", "minimum": 0 },
        "codec": { "type": "string" },
        "state": { "$ref": "#/$defs/DetectedVoiceState" }
      }
    },
    "DetectedTranscript": {
      "title": "DetectedTranscript",
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sentence_count", "state"],
      "properties": {
        "path": { "type": "string" },
        "sentence_count": { "type": "integer", "minimum": 0 },
        "state": { "$ref": "#/$defs/DetectedTranscriptState" }
      }
    },
    "SetupAlignment": {
      "title": "SetupAlignment",
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "hash", "device", "model", "audio_duration", "cache_hit"],
      "properties": {
        "status": { "$ref": "#/$defs/SetupAlignmentState" },
        "hash": { "type": "string" },
        "device": { "type": "string" },
        "model": { "type": "string" },
        "audio_duration": { "type": "number", "minimum": 0 },
        "cache_hit": { "type": "boolean" },
        "error": { "type": "string" }
      }
    },
    "SetupSubtitleGenerationState": {
      "title": "SetupSubtitleGenerationState",
      "enum": ["ready", "running", "succeeded", "failed"]
    },
    "SetupSubtitleCacheState": {
      "title": "SetupSubtitleCacheState",
      "enum": ["unknown", "hit", "miss"]
    },
    "SetupSubtitleGenerationResult": {
      "title": "SetupSubtitleGenerationResult",
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "cue_count", "total_duration_s", "cache_state"],
      "properties": {
        "status": { "$ref": "#/$defs/SetupSubtitleGenerationState" },
        "cue_count": { "type": "integer", "minimum": 0 },
        "total_duration_s": { "type": "number", "minimum": 0 },
        "cache_state": { "$ref": "#/$defs/SetupSubtitleCacheState" },
        "error_message": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
      }
    },
    "DetectedInputs": {
      "title": "DetectedInputs",
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "name", "voice", "transcript", "alignment"],
      "properties": {
        "path": { "type": "string" },
        "name": { "type": "string" },
        "voice": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/DetectedVoice" }] },
        "transcript": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/DetectedTranscript" }] },
        "alignment": { "$ref": "#/$defs/SetupAlignment" }
      }
    },
    "SetupDraft": {
      "title": "SetupDraft",
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "name", "output_preset", "voice", "transcript", "subtitle_generation", "alignment"],
      "properties": {
        "project_id": { "type": "string", "minLength": 1 },
        "path": { "type": "string" },
        "name": { "type": "string" },
        "output_preset": { "$ref": "#/$defs/SetupOutputPreset" },
        "voice": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/DetectedVoice" }] },
        "transcript": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/DetectedTranscript" }] },
        "subtitle_generation": { "$ref": "#/$defs/SetupSubtitleGenerationResult" },
        "alignment": { "$ref": "#/$defs/SetupAlignment" }
      }
    },
    "AlignmentStateResponse": {
      "title": "AlignmentStateResponse",
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "status", "cache_hit"],
      "properties": {
        "project_id": { "type": "string", "minLength": 1 },
        "status": { "$ref": "#/$defs/SetupAlignmentState" },
        "cache_hit": { "type": "boolean" },
        "hash": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "error": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
      }
    },
    "Transcript": {
      "title": "Transcript",
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path"],
      "properties": {
        "kind": { "enum": ["plain_text", "pre_segmented"] },
        "path": { "type": "string" },
        "sentences": {
          "type": "array",
          "items": { "$ref": "#/$defs/TranscriptSentenceCue" },
          "minItems": 1
        }
      }
    },
    "TranscriptSentenceCue": {
      "title": "TranscriptSentenceCue",
      "type": "object",
      "additionalProperties": false,
      "required": ["index", "text", "start_s", "end_s"],
      "properties": {
        "index": { "type": "integer", "minimum": 1 },
        "text": { "type": "string", "minLength": 1 },
        "start_s": { "type": "number", "minimum": 0 },
        "end_s": { "type": "number", "minimum": 0 },
        "confidence_avg": {
          "oneOf": [
            { "type": "number", "minimum": 0, "maximum": 1 },
            { "type": "null" }
          ]
        }
      }
    },
    "Output": {
      "title": "Output",
      "type": "object",
      "additionalProperties": false,
      "required": ["preset"],
      "properties": {
        "preset": { "enum": ["draft", "final"] },
        "resolution": { "enum": ["1080p", "720p", "9:16"] },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "fps": { "type": "number", "exclusiveMinimum": 0 },
        "video_codec": { "type": "string", "minLength": 1 },
        "video_crf": { "oneOf": [{ "type": "integer" }, { "type": "null" }] },
        "video_preset": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "audio_codec": { "type": "string", "minLength": 1 },
        "audio_bitrate_kbps": { "oneOf": [{ "type": "integer", "minimum": 1 }, { "type": "null" }] },
        "audio_sample_rate": { "oneOf": [{ "type": "integer", "minimum": 1 }, { "type": "null" }] },
        "pixel_format": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "color_space": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
      }
    },
    "Motion": {
      "title": "Motion",
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "easing"],
      "properties": {
        "kind": {
          "enum": [
            "none",
            "static",
            "ken_burns",
            "ken_burns_strong",
            "zoom_in",
            "zoom_out",
            "pan_left",
            "pan_right"
          ]
        },
        "easing": { "enum": ["linear", "ease_in", "ease_out", "ease_in_out"] }
      }
    },
    "Transitions": {
      "title": "Transitions",
      "type": "object",
      "additionalProperties": false,
      "required": ["in", "out"],
      "properties": {
        "in": { "enum": ["cut", "fade", "slide_left", "slide_right", "dip_black"] },
        "out": { "enum": ["cut", "fade", "slide_left", "slide_right", "dip_black"] }
      }
    },
    "SentenceRange": {
      "title": "SentenceRange",
      "type": "array",
      "prefixItems": [
        { "type": "integer", "minimum": 1 },
        { "type": "integer", "minimum": 1 }
      ],
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "integer", "minimum": 1 }
    },
    "VisualItemBase": {
      "title": "VisualItemBase",
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sentences", "start", "end", "motion", "transitions"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "mediaId": { "type": "string", "minLength": 1 },
        "mediaIds": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "anchor": { "enum": ["sentences", "time"] },
        "from": { "type": "string", "pattern": "^\\d{1,2}:\\d{2}:\\d{2}\\.\\d{3}$" },
        "to": { "type": "string", "pattern": "^\\d{1,2}:\\d{2}:\\d{2}\\.\\d{3}$" },
        "sentences": { "$ref": "#/$defs/SentenceRange" },
        "start": { "type": "number", "minimum": 0 },
        "end": { "type": "number", "minimum": 0 },
        "motion": { "$ref": "#/$defs/Motion" },
        "transitions": { "$ref": "#/$defs/Transitions" },
        "cache_status": { "$ref": "#/$defs/VisualCacheStatus" },
        "orphaned": { "type": "boolean" },
        "orphan_reason": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
      }
    },
    "VisualMediaRefConstraint": {
      "title": "VisualMediaRefConstraint",
      "type": "object",
      "anyOf": [{ "required": ["mediaId"] }, { "required": ["mediaIds"] }],
      "not": { "required": ["mediaId", "mediaIds"] }
    },
    "ForegroundItem": {
      "title": "ForegroundItem",
      "allOf": [
        { "$ref": "#/$defs/VisualItemBase" },
        { "$ref": "#/$defs/VisualMediaRefConstraint" }
      ]
    },
    "PipPlacement": {
      "title": "PipPlacement",
      "type": "object",
      "additionalProperties": false,
      "required": ["posX", "posY", "size", "radius", "opacity"],
      "properties": {
        "posX": { "type": "number", "minimum": 0, "maximum": 100 },
        "posY": { "type": "number", "minimum": 0, "maximum": 100 },
        "size": { "type": "number", "minimum": 15, "maximum": 60 },
        "radius": { "type": "number", "minimum": 0, "maximum": 32 },
        "opacity": { "type": "number", "minimum": 10, "maximum": 100 }
      }
    },
    "PipItem": {
      "title": "PipItem",
      "allOf": [
        { "$ref": "#/$defs/VisualItemBase" },
        { "$ref": "#/$defs/VisualMediaRefConstraint" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["pip"],
          "properties": {
            "pip": { "$ref": "#/$defs/PipPlacement" }
          }
        }
      ]
    },
    "BackgroundItem": {
      "title": "BackgroundItem",
      "allOf": [
        { "$ref": "#/$defs/VisualItemBase" },
        { "$ref": "#/$defs/VisualMediaRefConstraint" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["crossfade"],
          "properties": {
            "crossfade": { "type": "number", "minimum": 0 },
            "schedule": {
              "type": "array",
              "items": { "$ref": "#/$defs/BackgroundScheduleSegment" }
            }
          }
        }
      ]
    },
    "BackgroundScheduleSegment": {
      "title": "BackgroundScheduleSegment",
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "mediaId", "start", "end", "lockedDuration"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "mediaId": { "type": "string", "minLength": 1 },
        "start": { "type": "number", "minimum": 0 },
        "end": { "type": "number", "minimum": 0 },
        "lockedDuration": { "type": "boolean" }
      }
    },
    "SubtitlesItem": {
      "title": "SubtitlesItem",
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "auto", "label", "style"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "auto": { "const": true },
