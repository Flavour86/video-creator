{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video-creator.local/schemas/project.json",
  "title": "Project",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "name", "audio", "transcript", "output", "layers"],
  "properties": {
    "version": { "const": 1 },
    "name": { "type": "string", "minLength": 1, "maxLength": 200 },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "project_id": { "type": "string", "minLength": 1 },
    "config_hash": { "type": "string", "minLength": 1 },
    "last_rendered_config_hash": { "type": "string", "minLength": 1 },
    "audio": { "type": "string" },
    "transcript": { "$ref": "#/$defs/Transcript" },
    "output": { "$ref": "#/$defs/Output" },
    "media": {
      "type": "array",
      "items": { "$ref": "#/$defs/MediaAsset" }
    },
    "layers": {
      "type": "array",
      "description": "Ordered top-to-bottom in render stack: subtitles first, background last.",
      "items": {
        "oneOf": [
          { "$ref": "#/$defs/SubtitlesLayer" },
          { "$ref": "#/$defs/ForegroundLayer" },
          { "$ref": "#/$defs/PipLayer" },
          { "$ref": "#/$defs/BackgroundLayer" }
        ],
        "discriminator": { "propertyName": "kind" }
      }
    },
    "subtitles": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/SubtitlesSettings" }]
    },
    "watermark": {
      "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/Watermark" }]
    },
    "ai": {
      "oneOf": [{ "type": "null" }, { "type": "object", "additionalProperties": true }]
    },
    "characters": {
      "oneOf": [
        { "type": "null" },
        { "type": "array", "items": { "type": "object", "additionalProperties": true } }
      ]
    }
  },
  "$defs": {
    "RuntimeState": {
      "title": "RuntimeState",
      "enum": ["ready", "unavailable", "unknown"]
    },
    "AlignmentState": {
      "title": "AlignmentState",
      "enum": ["aligned", "pending", "missing"]
    },
    "SetupAlignmentState": {
      "title": "SetupAlignmentState",
      "enum": ["pending", "running", "aligned", "failed"]
    },
    "DetectedVoiceState": {
      "title": "DetectedVoiceState",
      "enum": ["copied", "copying", "invalid"]
    },
    "DetectedTranscriptState": {
      "title": "DetectedTranscriptState",
      "enum": ["parsed", "empty", "invalid"]
    },
    "ProjectStatus": {
      "title": "ProjectStatus",
      "enum": ["ready", "missing", "corrupt", "alignment_pending", "alignment_failed", "rendering"]
    },
    "RenderStatus": {
      "title": "RenderStatus",
      "enum": ["queued", "running", "done", "error", "cancelled", "partial"]
    },
    "RenderPreset": {
      "title": "RenderPreset",
      "enum": ["draft", "final"]
    },
    "RenderArtifactKind": {
      "title": "RenderArtifactKind",
      "enum": ["final_mp4", "draft_mp4", "partial", "log", "filtergraph", "subtitles", "thumbnail", "companion"]
    },
    "MediaKind": {
      "title": "MediaKind",
      "enum": ["image", "video", "audio", "watermark_image", "watermark_video"]
    },
    "MediaImportMode": {
      "title": "MediaImportMode",
      "enum": ["copy", "link", "generated"]
    },
    "VisualCacheStatus": {
      "title": "VisualCacheStatus",
      "enum": ["warm", "partial", "cold", "invalid", "orphaned"]
    },
    "Dimensions": {
      "title": "Dimensions",
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      }
    },
    "MediaAsset": {
      "title": "MediaAsset",
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "kind", "path", "import_mode", "imported_at"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "kind": { "$ref": "#/$defs/MediaKind" },
        "path": { "type": "string", "minLength": 1 },
        "thumb_path": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "dimensions": { "oneOf": [{ "$ref": "#/$defs/Dimensions" }, { "type": "null" }] },
        "duration": { "oneOf": [{ "type": "number", "minimum": 0 }, { "type": "null" }] },
        "size": { "oneOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] },
        "hash": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "import_mode": { "$ref": "#/$defs/MediaImportMode" },
        "imported_at": { "type": "string", "format": "date-time" }
      }
    },
    "SidecarStatus": {
      "title": "SidecarStatus",
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "address", "version"],
      "properties": {
        "status": { "$ref": "#/$defs/RuntimeState" },
        "address": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "VersionedRuntimeStatus": {
      "title": "VersionedRuntimeStatus",
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "version"],
      "properties": {
        "status": { "$ref": "#/$defs/RuntimeState" },
        "version": { "type": "string" }
      }
    },
    "CudaStatus": {
      "title": "CudaStatus",
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "available", "version", "gpu_label"],
      "properties": {
        "status": { "$ref": "#/$defs/RuntimeState" },
        "available": { "oneOf": [{ "type": "boolean" }, { "type": "null" }] },
        "version": { "type": "string" },
        "gpu_label": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
      }
    },
    "WhisperXStatus": {
      "title": "WhisperXStatus",
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "model"],
      "properties": {
        "status": { "$ref": "#/$defs/RuntimeState" },
        "model": { "type": "string" }
      }
    },
    "RuntimeHealthResponse": {
      "title": "RuntimeHealthResponse",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "version",
        "active_renders",
        "cached_projects",
        "sidecar",
        "node",
        "python",
        "ffmpeg",
        "cuda",
        "whisperx"
      ],
      "properties": {
        "status": { "const": "ok" },
        "version": { "type": "string" },
        "active_renders": { "type": "integer", "minimum": 0 },
        "cached_projects": { "type": "integer", "minimum": 0 },
        "sidecar": { "$ref": "#/$defs/SidecarStatus" },
        "node": { "$ref": "#/$defs/VersionedRuntimeStatus" },
        "python": { "$ref": "#/$defs/VersionedRuntimeStatus" },
        "ffmpeg": { "$ref": "#/$defs/VersionedRuntimeStatus" },
        "cuda": { "$ref": "#/$defs/CudaStatus" },
        "whisperx": { "$ref": "#/$defs/WhisperXStatus" }
      }
    },
    "RecentProject": {
      "title": "RecentProject",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "name",
        "last_opened_at",
        "voice_duration",
        "sentence_count",
        "media_count",
        "alignment_state",
        "palette_seed"
      ],
      "properties": {
        "path": { "type": "string" },
        "name": { "type": "string" },
        "last_opened_at": { "type": "string" },
        "voice_duration": { "type": "string" },
        "sentence_count": { "type": "integer", "minimum": 0 },
        "media_count": { "type": "integer", "minimum": 0 },
        "alignment_state": { "$ref": "#/$defs/AlignmentState" },
        "palette_seed": { "type": "string" }
      }
    },
    "RecentProjectCard": {
      "title": "RecentProjectCard",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "project_id",
        "name",
        "last_opened_at",
        "voice_duration",
        "sentence_count",
        "media_count",
        "alignment_state",
        "status",
        "has_unrendered_changes"
      ],
      "properties": {
        "project_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "last_opened_at": { "type": "string" },
        "voice_duration": { "type": "string" },
        "sentence_count": { "type": "integer", "minimum": 0 },
        "media_count": { "type": "integer", "minimum": 0 },
        "alignment_state": { "$ref": "#/$defs/AlignmentState" },
        "status": { "$ref": "#/$defs/ProjectStatus" },
        "thumbnail_path": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "current_config_hash": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "last_rendered_config_hash": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "has_unrendered_changes": { "type": "boolean" },
        "latest_render_id": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "latest_render_status": { "oneOf": [{ "$ref": "#/$defs/RenderStatus" }, { "type": "null" }] }
      }
    },
    "DetectedVoice": {
      "title": "DetectedVoice",
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "duration", "sample_rate", "channels", "codec", "state"],
      "properties": {
        "path": { "type": "string" },
        "duration": { "type": "number", "minimum": 0 },
        "sample_rate": { "type": "integer", "minimum": 0 },
        "channels": { "type": "integer", "minimum": 0 },
        "codec": { "type": "string" },
        "state": { "$ref": "#/$defs/DetectedVoiceState" }
      }
    },
    "DetectedTranscript": {
      "title": "DetectedTranscript",
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sentence_count", "state"],
      "properties": {
        "path": { "type": "string" },
        "sentence_count": { "type": "integer", "minimum": 0 },
        "state": { "$ref": "#/$defs/DetectedTranscriptState" }
      }
    },
    "SetupAlignment": {
      "title": "SetupAlignment",
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "hash", "device", "model", "audio_duration", "cache_hit"],
      "properties": {
        "status": { "$ref": "#/$defs/SetupAlignmentState" },
        "hash": { "type": "string" },
        "device": { "type": "string" },
        "model": { "type": "string" },
        "audio_duration": { "type": "number", "minimum": 0 },
        "cache_hit": { "type": "boolean" },
        "error": { "type": "string" }
      }
    },
    "DetectedInputs": {
      "title": "DetectedInputs",
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "name", "voice", "transcript", "alignment"],
      "properties": {
        "path": { "type": "string" },
        "name": { "type": "string" },
        "voice": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/DetectedVoice" }] },
        "transcript": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/DetectedTranscript" }] },
        "alignment": { "$ref": "#/$defs/SetupAlignment" }
      }
    },
    "SetupDraft": {
      "title": "SetupDraft",
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "name", "output_preset", "voice", "transcript", "alignment"],
      "properties": {
        "project_id": { "type": "string", "minLength": 1 },
        "path": { "type": "string" },
        "name": { "type": "string" },
        "output_preset": { "type": "string" },
        "voice": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/DetectedVoice" }] },
        "transcript": { "oneOf": [{ "type": "null" }, { "$ref": "#/$defs/DetectedTranscript" }] },
        "alignment": { "$ref": "#/$defs/SetupAlignment" }
      }
    },
    "AlignmentStateResponse": {
      "title": "AlignmentStateResponse",
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "status", "cache_hit"],
      "properties": {
        "project_id": { "type": "string", "minLength": 1 },
        "status": { "$ref": "#/$defs/SetupAlignmentState" },
        "cache_hit": { "type": "boolean" },
        "hash": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "error": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
      }
    },
    "Transcript": {
      "title": "Transcript",
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "path"],
      "properties": {
        "kind": { "enum": ["plain_text", "pre_segmented"] },
        "path": { "type": "string" }
      }
    },
    "Output": {
      "title": "Output",
      "type": "object",
      "additionalProperties": false,
      "required": ["preset"],
      "properties": {
        "preset": { "enum": ["draft", "final"] }
      }
    },
    "Motion": {
      "title": "Motion",
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "easing"],
      "properties": {
        "kind": {
          "enum": [
            "none",
            "static",
            "ken_burns",
            "ken_burns_strong",
            "zoom_in",
            "zoom_out",
            "pan_left",
            "pan_right"
          ]
        },
        "easing": { "enum": ["linear", "ease_in", "ease_out", "ease_in_out"] }
      }
    },
    "Transitions": {
      "title": "Transitions",
      "type": "object",
      "additionalProperties": false,
      "required": ["in", "out"],
      "properties": {
        "in": { "enum": ["cut", "fade", "slide_left", "slide_right", "dip_black"] },
        "out": { "enum": ["cut", "fade", "slide_left", "slide_right", "dip_black"] }
      }
    },
    "SentenceRange": {
      "title": "SentenceRange",
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": { "type": "integer", "minimum": 1 }
    },
    "VisualItemBase": {
      "title": "VisualItemBase",
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "mediaId", "sentences", "start", "end", "motion", "transitions"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "mediaId": { "type": "string", "minLength": 1 },
        "mediaIds": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "anchor": { "enum": ["sentences", "time"] },
        "from": { "type": "string", "pattern": "^\\d{1,2}:\\d{2}:\\d{2}\\.\\d{3}$" },
        "to": { "type": "string", "pattern": "^\\d{1,2}:\\d{2}:\\d{2}\\.\\d{3}$" },
        "sentences": { "$ref": "#/$defs/SentenceRange" },
        "start": { "type": "number", "minimum": 0 },
        "end": { "type": "number", "minimum": 0 },
        "motion": { "$ref": "#/$defs/Motion" },
        "transitions": { "$ref": "#/$defs/Transitions" },
        "cache_status": { "$ref": "#/$defs/VisualCacheStatus" },
        "orphaned": { "type": "boolean" },
        "orphan_reason": { "oneOf": [{ "type": "string" }, { "type": "null" }] }
      }
    },
    "ForegroundItem": {
      "title": "ForegroundItem",
      "allOf": [{ "$ref": "#/$defs/VisualItemBase" }]
    },
    "PipPlacement": {
      "title": "PipPlacement",
      "type": "object",
      "additionalProperties": false,
      "required": ["posX", "posY", "size", "radius", "opacity"],
      "properties": {
        "posX": { "type": "number", "minimum": 0, "maximum": 100 },
        "posY": { "type": "number", "minimum": 0, "maximum": 100 },
        "size": { "type": "number", "minimum": 10, "maximum": 70 },
        "radius": { "type": "number", "minimum": 0 },
        "opacity": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "PipItem": {
      "title": "PipItem",
      "allOf": [
        { "$ref": "#/$defs/VisualItemBase" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["pip"],
          "properties": {
            "pip": { "$ref": "#/$defs/PipPlacement" }
          }
        }
      ]
    },
    "BackgroundItem": {
      "title": "BackgroundItem",
      "allOf": [
        { "$ref": "#/$defs/VisualItemBase" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["crossfade"],
          "properties": {
            "crossfade": { "type": "number", "minimum": 0 }
          }
        }
      ]
    },
    "SubtitlesItem": {
      "title": "SubtitlesItem",
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "auto", "label", "style"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "auto": { "const": true },
        "label": { "type": "string" },
        "style": { "const": "default" }
      }
    },
    "SubtitlesLayer": {
      "title": "SubtitlesLayer",
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "name", "items"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "const": "sub" },
        "name": { "type": "string" },
        "items": { "type": "array", "items": { "$ref": "#/$defs/SubtitlesItem" } }
      }
    },
    "ForegroundLayer": {
      "title": "ForegroundLayer",
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "name", "items"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "const": "fg" },
        "name": { "type": "string" },
        "items": { "type": "array", "items": { "$ref": "#/$defs/ForegroundItem" } }
      }
    },
    "PipLayer": {
      "title": "PipLayer",
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "name", "items"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "const": "pip" },
        "name": { "type": "string" },
        "items": { "type": "array", "items": { "$ref": "#/$defs/PipItem" } }
      }
    },
    "BackgroundLayer": {
      "title": "BackgroundLayer",
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "name", "items"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "const": "bg" },
        "name": { "type": "string" },
        "items": { "type": "array", "items": { "$ref": "#/$defs/BackgroundItem" } }
      }
    },
    "SubtitleStyle": {
      "title": "SubtitleStyle",
      "type": "object",
      "additionalProperties": false,
      "required": ["font", "size", "position", "max_chars_per_line", "bg_style"],
      "properties": {
        "font": { "type": "string" },
        "size": { "type": "number", "minimum": 1 },
        "position": { "enum": ["bottom-center", "top-center"] },
        "max_chars_per_line": { "type": "integer", "minimum": 1 },
        "bg_style": { "enum": ["none", "shadow", "box"] }
      }
    },
    "SubtitlesSettings": {
      "title": "SubtitlesSettings",
      "type": "object",
      "additionalProperties": false,
      "required": ["burn_in", "style"],
      "properties": {
        "burn_in": { "type": "boolean" },
        "style": { "$ref": "#/$defs/SubtitleStyle" }
      }
    },
    "Watermark": {
      "title": "Watermark",
      "type": "object",
      "additionalProperties": false,
      "required": ["mediaId", "posX", "posY", "scale", "opacity"],
      "properties": {
        "mediaId": { "type": "string", "minLength": 1 },
        "posX": { "type": "number", "minimum": 0, "maximum": 100 },
        "posY": { "type": "number", "minimum": 0, "maximum": 100 },
        "scale": { "type": "number", "minimum": 0 },
        "opacity": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "RenderArtifact": {
      "title": "RenderArtifact",
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_id", "render_id", "project_id", "kind", "path", "created_at", "playable", "reusable"],
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1 },
        "render_id": { "type": "string", "minLength": 1 },
        "project_id": { "type": "string", "minLength": 1 },
        "kind": { "$ref": "#/$defs/RenderArtifactKind" },
        "path": { "type": "string", "minLength": 1 },
        "size": { "oneOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] },
        "hash": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "created_at": { "type": "string", "format": "date-time" },
        "playable": { "type": "boolean" },
        "reusable": { "type": "boolean" }
      }
    },
    "RenderHistoryRow": {
      "title": "RenderHistoryRow",
      "type": "object",
      "additionalProperties": false,
      "required": ["render_id", "project_id", "preset", "status", "created_at", "artifacts"],
      "properties": {
        "render_id": { "type": "string", "minLength": 1 },
        "project_id": { "type": "string", "minLength": 1 },
        "preset": { "$ref": "#/$defs/RenderPreset" },
        "status": { "$ref": "#/$defs/RenderStatus" },
        "filename": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "resolution": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "duration": { "oneOf": [{ "type": "number", "minimum": 0 }, { "type": "null" }] },
        "file_size": { "oneOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }] },
        "config_hash": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "created_at": { "type": "string", "format": "date-time" },
        "completed_at": { "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] },
        "artifacts": { "type": "array", "items": { "$ref": "#/$defs/RenderArtifact" } }
      }
    },
    "ProjectConfigLoadResponse": {
      "title": "ProjectConfigLoadResponse",
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "config", "config_hash", "has_unrendered_changes"],
      "properties": {
        "project_id": { "type": "string", "minLength": 1 },
        "config": { "$ref": "#" },
        "config_hash": { "type": "string", "minLength": 1 },
        "last_rendered_config_hash": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
        "has_unrendered_changes": { "type": "boolean" }
      }
    },
    "ProjectConfigSaveResponse": {
      "title": "ProjectConfigSaveResponse",
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "config_hash", "saved_at", "has_unrendered_changes"],
      "properties": {
        "project_id": { "type": "string", "minLength": 1 },
        "config_hash": { "type": "string", "minLength": 1 },
        "saved_at": { "type": "string", "format": "date-time" },
        "has_unrendered_changes": { "type": "boolean" }
      }
    }
  }
}
